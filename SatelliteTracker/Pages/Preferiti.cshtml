@page
@model SatelliteTracker.Pages.PreferitiModel

<h2>Satelliti Preferiti</h2>

<ul>
    @foreach (var sat in Model.Satellites)
    {
        <li>
            @sat.SatName (ID: @sat.SatId)

            <form method="post"  asp-page-handler="Remove" style="display:inline;">
                <input type="hidden" name="satId" value="@sat.SatId"/>
                <button type="submit">cancella</button>
            </form>

        </li>
    }
</ul>
<div id="map" style="height: 500px; margin-top:20px;"></div>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
    var mappa = L.map('map').setView([20, 0], 2);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(mappa);

    var satelliti = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Satellites
                        .Where(s => s.SatLat != null && s.SatLng != null)
                        .Select(s => new { id = s.SatId, nome = s.SatName, lat = s.SatLat, lng = s.SatLng })
        ));

    var segnaposti = satelliti.map(s =>
        L.marker([s.lat, s.lng]).addTo(mappa).bindPopup("🛰️ " + s.nome)
    );

    async function aggiorna() {
        await Promise.all(segnaposti.map(async (segnaposto, i) => {
            try {
                var risposta = await fetch(`/Search?handler=Satellite&satId=${satelliti[i].id}`);
                var dati = await risposta.json();
                segnaposto.setLatLng([dati.latitude, dati.longitude]);
            } catch { }
        }));
    }

    aggiorna();
    setInterval(aggiorna, 10000);
</script>